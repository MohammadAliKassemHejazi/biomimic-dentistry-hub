# ── Required ───────────────────────────────────────────────────────────────────

# PostgreSQL (Neon free tier recommended)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Redis (Upstash free tier recommended — use rediss:// for TLS)
REDIS_URL=rediss://default:password@host:6379

# Auth
JWT_SECRET=replace_with_a_long_random_secret

# ── Payment ─────────────────────────────────────────────────────────────────────

# Stripe
STRIPE_SECRET_KEY=sk_test_...

# PayPal (sandbox for testing, live for production)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# ── URLs ────────────────────────────────────────────────────────────────────────

# Public URL of the Next.js client (used for Stripe/PayPal redirect URLs and CORS)
CLIENT_URL=https://your-client.onrender.com

# ── Email ───────────────────────────────────────────────────────────────────────

EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── Runtime ─────────────────────────────────────────────────────────────────────

NODE_ENV=production

# Set to true on first deploy to create the database schema, then remove/set to false
SYNC_DB=false
