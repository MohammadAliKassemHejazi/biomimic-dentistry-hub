# =============================================================================
# DEVELOPMENT ENVIRONMENT
# =============================================================================
# Copy this file to `.env.development` (git-ignored) OR to `.env` (the one
# docker-compose reads by default) and fill in your local values.
#
# Usage with docker-compose:
#   cp .env.development.example .env
#   docker compose up
#
# Usage without Docker (running server/client with npm):
#   cp .env.development.example server/.env    # for the server
#   cp .env.development.example .env           # for the Next.js client (NEXT_PUBLIC_* only)
# =============================================================================


# ─── PostgreSQL (docker-compose `db` service) ────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_db

# Full connection string — used by server/src/config/database.ts.
# Inside Docker: host is `db` (service name). Outside Docker: `localhost`.
DATABASE_URL=postgres://postgres:postgres@db:5432/app_db


# ─── Redis (docker-compose `redis` service) ──────────────────────────────────
# Inside Docker: `redis`. Outside Docker: `localhost`.
REDIS_URL=redis://redis:6379


# ─── Auth ────────────────────────────────────────────────────────────────────
# Long random string. Do NOT use this dev value in prod.
# Generate one: `openssl rand -base64 48`
JWT_SECRET=dev_only_replace_me_with_random_string


# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# Set to "true" the very first time you boot against a fresh DB to create
# the schema via Sequelize sync. After that, leave it "false".
SYNC_DB=true


# ─── URLs ────────────────────────────────────────────────────────────────────
# Where the Next.js client is reachable (used for CORS + Stripe/PayPal redirects).
CLIENT_URL=http://localhost:3000

# Where the browser calls the Express API. Must be public (NEXT_PUBLIC_*).
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Used by Next.js rewrites() to proxy /uploads/* to the Express server.
# Inside Docker: `http://server:5000`. Outside Docker: `http://localhost:5000`.
SERVER_INTERNAL_URL=http://server:5000


# ─── Stripe (test mode) ──────────────────────────────────────────────────────
# Get a test key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_test_key


# ─── PayPal (sandbox) ────────────────────────────────────────────────────────
# Get sandbox creds from https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id
PAYPAL_CLIENT_SECRET=your_paypal_sandbox_client_secret
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com


# ─── Email (optional in dev) ─────────────────────────────────────────────────
# Gmail + App Password. Leave blank to disable email features locally.
EMAIL_USER=
EMAIL_PASS=


# ─── App env (client) ────────────────────────────────────────────────────────
APP_ENV=development
