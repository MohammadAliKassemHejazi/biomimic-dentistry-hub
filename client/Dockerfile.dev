FROM node:20-alpine

WORKDIR /app

ENV NEXT_TELEMETRY_DISABLED=1

COPY package*.json ./

RUN npm install

COPY . .

EXPOSE 3000

# APP_ENV=production → build then start; anything else → dev server
CMD sh -c 'if [ "$APP_ENV" = "production" ]; then npm run build && npm run start; else npm run dev; fi'
