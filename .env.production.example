# =============================================================================
# PRODUCTION ENVIRONMENT
# =============================================================================
# Reference template for production env vars. Do NOT commit a filled-in version.
#
# On Render: set these in the service dashboard (Environment tab). The
# `render.yaml` in this repo already lists the keys — use this file to look up
# what each one means and what format to use.
#
# On other hosts (Railway, Fly, VPS): copy to `.env.production`, fill in, and
# make sure your process manager / container runtime loads it.
# =============================================================================


# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# Set to "true" ONLY for the very first deploy against an empty database, so
# Sequelize creates the schema. Immediately set back to "false" afterwards.
# Long-term: replace sync with a real migration tool.
SYNC_DB=false


# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Managed Postgres (Neon / Supabase / RDS). Must include sslmode=require.
# Example: postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=


# ─── Redis ───────────────────────────────────────────────────────────────────
# Managed Redis (Upstash). Use rediss:// (TLS) in production.
# Example: rediss://default:password@fly-example.upstash.io:6379
REDIS_URL=


# ─── Auth ────────────────────────────────────────────────────────────────────
# MUST be a long random string. Generate: `openssl rand -base64 48`.
# Never reuse the dev secret. Rotate on any suspected compromise.
JWT_SECRET=


# ─── URLs ────────────────────────────────────────────────────────────────────
# Public URL of the Next.js client. Used for CORS + Stripe/PayPal redirects.
CLIENT_URL=https://your-client-domain.com

# Public API URL that the browser calls. Usually CLIENT_URL's API sibling.
NEXT_PUBLIC_API_URL=https://your-server-domain.com/api

# Internal URL used by Next.js rewrites() to proxy /uploads/*.
# On Render: same as the server's public URL (no /api suffix).
SERVER_INTERNAL_URL=https://your-server-domain.com


# ─── Stripe (live) ───────────────────────────────────────────────────────────
# Use a live key (sk_live_...) only in production.
STRIPE_SECRET_KEY=sk_live_


# ─── PayPal (live) ───────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BASE_URL=https://api-m.paypal.com


# ─── Email ───────────────────────────────────────────────────────────────────
# Gmail address + App Password (NOT your account password).
# Or swap for a transactional provider (SendGrid/Postmark/SES) — requires code change.
EMAIL_USER=
EMAIL_PASS=


# ─── Seed admin (new — see AUDIT.md §1.2) ────────────────────────────────────
# If you keep the seed-admin flow, set these. Otherwise remove the seed call.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
